{
  "name": "mdtxt",
  "version": "1.4.1",
  "description": "Minimalist Desktop File Browser - Browse and preview .md and .txt files",
  "main": "./out/main/index.js",
  "homepage": "https://github.com/sudosaudi/mdtxt",
  "author": {
    "name": "sudosaudi",
    "email": "sudosaudi@users.noreply.github.com"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:win": "electron-vite build && electron-builder --win",
    "preview": "electron-vite preview"
  },
  "keywords": [
    "electron",
    "markdown",
    "txt",
    "browser",
    "linux",
    "windows"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.1.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.14",
    "vite": "^5.2.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.61.0"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.12",
    "electron-updater": "^6.8.3",
    "framer-motion": "^11.2.4",
    "highlight.js": "^11.9.0",
    "lucide-react": "^0.378.0",
    "marked": "^18.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "tailwindcss": "^3.4.3"
  },
  "build": {
    "appId": "com.mdtxt.app",
    "productName": "MDTXT",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    },
    "deb": {
      "depends": [],
      "afterInstall": "scripts/afterInstall.sh"
    },
    "publish": {
      "provider": "github",
      "owner": "sudosaudi",
      "repo": "MDTXT"
    }
  }
}
